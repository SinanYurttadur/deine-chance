# Supabase Konfiguration
# Hole diese Werte aus deinem Supabase Dashboard:
# https://supabase.com/dashboard/project/DEIN_PROJEKT/settings/api

VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key

# Stripe Konfiguration
# Hole diese Werte aus deinem Stripe Dashboard:
# https://dashboard.stripe.com/test/apikeys

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_DEINE_PUBLISHABLE_KEY_HIER

# WICHTIG: Der Stripe Secret Key (sk_test_...) gehört NICHT in diese Datei!
# Er wird nur serverseitig in der Supabase Edge Function verwendet.
# Setze ihn als Supabase Secret: supabase secrets set STRIPE_SECRET_KEY=sk_test_...
