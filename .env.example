# ============================================================
# Deine Chance e.V. - Environment Variables
# ============================================================
# Kopiere diese Datei zu .env und fülle die Werte aus.
# .env ist in .gitignore und wird NICHT commited.
# ============================================================

# --- Frontend (VITE_ Prefix = im Browser sichtbar) ----------

# Supabase
# Dashboard: https://supabase.com/dashboard/project/DEIN_PROJEKT/settings/api
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key

# Stripe Publishable Key (pk_live_ oder pk_test_)
# Dashboard: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_DEIN_KEY

# --- Server-only (Vercel Environment Variables) --------------
# Diese Werte NUR in Vercel Dashboard → Settings → Environment Variables setzen.
# NIEMALS in .env oder im Frontend-Code verwenden!

# Stripe Secret Key (sk_live_ oder sk_test_)
# STRIPE_SECRET_KEY=sk_test_DEIN_KEY

# Stripe Webhook Secret (whsec_...)
# Erstellen unter: Stripe Dashboard → Developers → Webhooks → Add Endpoint
# URL: https://deinechance24.org/api/stripe-webhook
# Event: checkout.session.completed
# STRIPE_WEBHOOK_SECRET=whsec_DEIN_SECRET

# Supabase Service Role Key (NICHT der Anon Key!)
# Dashboard: https://supabase.com/dashboard/project/DEIN_PROJEKT/settings/api
# SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# Site URL (für Stripe Redirect-URLs)
# SITE_URL=https://deinechance24.org

# Allowed Origin (CORS)
# ALLOWED_ORIGIN=https://deinechance24.org
